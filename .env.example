# Real-YouTrack integration + E2E harness configuration.
# Copy to `.env` (git-ignored) and fill in for LOCAL runs only. NEVER commit secrets.
#
# The harness launches a LOCAL YouTrack Server WITHOUT Docker and hard-blocks
# production URLs. Destructive provisioning/seeding/cleanup only runs when
# YT_TEST_ALLOW_DESTRUCTIVE=true.

# Base URL of the local instance (must be localhost / 127.0.0.1). Leaving this unset
# makes every integration + E2E test self-skip.
YT_TEST_BASE_URL=

# Permanent admin token (Profile > Account Security > New token) for REST bootstrap.
YT_TEST_ADMIN_TOKEN=

# Capacity manager persona.
YT_TEST_MANAGER_LOGIN=
YT_TEST_MANAGER_PASSWORD=

# Team member personas.
YT_TEST_ALICE_LOGIN=
YT_TEST_ALICE_PASSWORD=
YT_TEST_BOB_LOGIN=
YT_TEST_BOB_PASSWORD=

# Isolation prefix for seeded projects (project becomes <PREFIX>_<runId>).
YT_TEST_PROJECT_PREFIX=SCP_E2E

# Safety gate — MUST be exactly "true" to allow provisioning / seeding / cleanup.
YT_TEST_ALLOW_DESTRUCTIVE=

# --- Optional / advanced ---
# Local port for the launched instance (default 8080).
YT_TEST_PORT=
# Readiness poll timeout in ms (default 300000).
YT_TEST_READY_TIMEOUT_MS=
# Minimum acceptable E2E video duration in seconds (default 1).
YT_TEST_MIN_VIDEO_SEC=
# Seeded ids exported for the E2E specs (set by the harness; usually not by hand).
YT_TEST_PROJECT_ID=
YT_TEST_BOARD_ID=
# Escape hatch to allow a non-local host (disposable CI only; leave UNSET normally).
YT_TEST_ALLOW_NONLOCAL=
